{
  "name": "@fadouse/pi-permission",
  "version": "0.1.2",
  "description": "Native permission and sandbox extension for pi.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/*.js",
    "README.md"
  ],
  "keywords": ["pi-package", "pi", "permission", "sandbox"],
  "pi": {
    "extensions": ["./src/index.js"]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test",
    "check:legacy-sandbox-artifacts": "node --test test/no-legacy-sandbox-artifacts.test.js"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
